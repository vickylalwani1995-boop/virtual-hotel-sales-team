# =================================================================
# Environment variables for my Sales TEAM AI
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored so it never leaves your machine.
# =================================================================

# REQUIRED — Anthropic API key
# Used by every agent route + the Concierge chat + Call Simulator.
# Get yours: https://console.anthropic.com/settings/keys
# Key starts with "sk-ant-..."
ANTHROPIC_API_KEY=sk-ant-your-real-key-here

# Optional — Claude model to use (defaults handled in code).
# ANTHROPIC_MODEL=claude-sonnet-4-6
